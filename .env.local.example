# AI Models
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# ─── Facebook OAuth (required for /api/auth/facebook/* routes) ───────────────
# Get from: https://developers.facebook.com → Your App → Settings → Basic
FB_APP_ID=1267157968709745
FB_APP_SECRET=your_app_secret_here

# Callback URL — must match exactly what's registered in FB App → OAuth → Valid OAuth Redirect URIs
FB_REDIRECT_URI=https://loveintea.wealthpsy.com/api/auth/facebook/callback

# AES-256-GCM key for encrypting stored tokens. Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key_here

# ─── Legacy (auto-populated by OAuth flow, or set manually for dev) ──────────
# These are kept in sync by the OAuth callback so existing publish code works.
# You no longer need to set these manually — the OAuth flow writes them.
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
