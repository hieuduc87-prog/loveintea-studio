# Secrets & local env — MUST NOT be baked into image layers (Docker ignores .gitignore)
.env
.env.*
!.env.example
._*
.DS_Store

# VCS & CI
.git
.gitignore
.github

# Build output & deps (rebuilt inside the image)
node_modules
.next
out
dist
build

